#!/usr/bin/env python3
"""
nagios-cmd

Custom Nagios Core configuration manager for the anro_nagios Ansible role.

This script is intentionally self-contained and dependency-free. It uses only the
Python standard library so it can be installed directly by Ansible onto Ubuntu
20.04+ hosts without requiring pip modules.

Design goals
============

1. Keep Ansible-owned defaults separate from custom configuration.
2. Keep hosts in a hostgroup-based directory layout.
3. Use service definition templates for common service blocks.
4. Prompt before overwriting or removing files unless -f/--force is supplied.
5. Validate Nagios configuration after writes/removals and roll back failed writes.

Environment overrides
=====================

NAGIOS_BASE       Defaults to /etc/nagios if it exists, otherwise /etc/nagios4.
NAGIOS_CFG        Defaults to $NAGIOS_BASE/nagios.cfg.
NAGIOS_BIN        Defaults to /usr/sbin/nagios4.
NAGIOS_SERVICE    Defaults to nagios4.
NAGIOS_BACKUP_DIR Defaults to $NAGIOS_BASE/backup.
"""

from __future__ import annotations

import argparse
import datetime as dt
import os
import re
import shutil
import subprocess
import sys
import tarfile
import tempfile
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, Iterable, List, Optional


# Object names are allowed to contain common Nagios-safe characters.
# We reject '/' to prevent path traversal outside managed directories.
SAFE_NAME_RE = re.compile(r"^[A-Za-z0-9_.:-]+$")

# Hosts without an explicit hostgroup are placed here.
DEFAULT_HOSTGROUP = "default"


def detect_base() -> Path:
    """Detect the Nagios configuration base directory."""
    env_value = os.environ.get("NAGIOS_BASE")
    if env_value:
        return Path(env_value)
    if Path("/etc/nagios").exists():
        return Path("/etc/nagios")
    return Path("/etc/nagios4")


BASE = detect_base()
NAGIOS_CFG = Path(os.environ.get("NAGIOS_CFG", str(BASE / "nagios.cfg")))
NAGIOS_BIN = os.environ.get("NAGIOS_BIN", "/usr/sbin/nagios4")
NAGIOS_SERVICE = os.environ.get("NAGIOS_SERVICE", "nagios4")
BACKUP_DIR = Path(os.environ.get("NAGIOS_BACKUP_DIR", str(BASE / "backup")))

OBJECTS_DIR = BASE / "objects"
HOSTS_DIR = OBJECTS_DIR / "hosts"
SERVICEDEFS_DIR = BASE / "servicedefs"


# Metadata for supported Nagios object resources.
RESOURCE_META = {
    "host": {
        "object_type": "host",
        "name_key": "host_name",
        "custom_dir": HOSTS_DIR,
        "default_files": [OBJECTS_DIR / "hosts.cfg", OBJECTS_DIR / "localhost.cfg"],
    },
    "hostgroup": {
        "object_type": "hostgroup",
        "name_key": "hostgroup_name",
        "custom_dir": HOSTS_DIR,
        "default_files": [OBJECTS_DIR / "hostgroups.cfg"],
    },
    "service": {
        "object_type": "service",
        "name_key": "service_description",
        "custom_dir": HOSTS_DIR,
        "default_files": [OBJECTS_DIR / "services.cfg", OBJECTS_DIR / "localhost.cfg"],
    },
    "servicegroup": {
        "object_type": "servicegroup",
        "name_key": "servicegroup_name",
        "custom_dir": OBJECTS_DIR / "servicegroups",
        "default_files": [OBJECTS_DIR / "servicegroups.cfg"],
    },
    "contact": {
        "object_type": "contact",
        "name_key": "contact_name",
        "custom_dir": OBJECTS_DIR / "contacts",
        "default_files": [OBJECTS_DIR / "contacts.cfg"],
    },
    "contactgroup": {
        "object_type": "contactgroup",
        "name_key": "contactgroup_name",
        "custom_dir": OBJECTS_DIR / "contactgroups",
        "default_files": [OBJECTS_DIR / "contactgroups.cfg"],
    },
    "command": {
        "object_type": "command",
        "name_key": "command_name",
        "custom_dir": OBJECTS_DIR / "commands",
        "default_files": [OBJECTS_DIR / "commands.cfg"],
    },
    "template": {
        "object_type": None,
        "name_key": "name",
        "custom_dir": OBJECTS_DIR / "templates",
        "default_files": [OBJECTS_DIR / "templates.cfg"],
    },
    "timeperiod": {
        "object_type": "timeperiod",
        "name_key": "timeperiod_name",
        "custom_dir": OBJECTS_DIR / "timeperiods",
        "default_files": [OBJECTS_DIR / "timeperiods.cfg"],
    },
}


class NagiosCmdError(Exception):
    """Operational error that should be printed without a Python traceback."""


@dataclass
class NagiosObject:
    """Parsed representation of one Nagios object block."""
    object_type: str
    fields: Dict[str, str]
    path: Path
    start: int
    end: int
    raw: str


def die(message: str, code: int = 1) -> None:
    """Print a user-facing error message and exit."""
    print(f"ERROR: {message}", file=sys.stderr)
    raise SystemExit(code)


def safe_name(value: str, label: str = "name") -> str:
    """Validate a filesystem-safe object name and return it."""
    if not value:
        die(f"{label} cannot be empty")
    if "/" in value or value in {".", ".."} or not SAFE_NAME_RE.match(value):
        die(
            f"invalid {label}: {value!r}; allowed characters are letters, "
            "numbers, dot, underscore, dash, and colon"
        )
    return value


def parse_options(values: Optional[List[str]]) -> Dict[str, str]:
    """Parse repeated -o/--options values into a directive dictionary."""
    options: Dict[str, str] = {}
    if not values:
        return options
    for raw_value in values:
        for raw_part in raw_value.split(","):
            part = raw_part.strip()
            if not part:
                continue
            if "=" not in part:
                die(f"invalid option {part!r}; expected key=value")
            key, value = part.split("=", 1)
            key = key.strip()
            value = value.strip()
            if not key:
                die(f"invalid option {part!r}; key cannot be empty")
            options[key] = value
    return options


def confirm(prompt: str, force: bool = False) -> None:
    """Confirm destructive or overwrite operations unless force is set."""
    if force:
        return
    answer = input(f"{prompt} [y/N]: ").strip().lower()
    if answer not in {"y", "yes"}:
        die("aborted")


def ensure_layout() -> None:
    """Create the custom configuration directory skeleton if missing."""
    paths = [OBJECTS_DIR, HOSTS_DIR, HOSTS_DIR / DEFAULT_HOSTGROUP, SERVICEDEFS_DIR, BACKUP_DIR]
    for meta in RESOURCE_META.values():
        paths.append(meta["custom_dir"])
    for path in paths:
        path.mkdir(parents=True, exist_ok=True)


def read_text(path: Path) -> str:
    """Read a UTF-8 file or exit cleanly if it is missing."""
    try:
        return path.read_text(encoding="utf-8")
    except FileNotFoundError:
        die(f"file not found: {path}")


def run_command(command: List[str]) -> subprocess.CompletedProcess:
    """Run a command and capture combined stdout/stderr."""
    return subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)


def validate_config() -> None:
    """Validate Nagios configuration with nagios4 -v."""
    if not Path(NAGIOS_BIN).exists():
        die(f"Nagios binary not found: {NAGIOS_BIN}")
    if not NAGIOS_CFG.exists():
        die(f"Nagios config not found: {NAGIOS_CFG}")
    result = run_command([NAGIOS_BIN, "-v", str(NAGIOS_CFG)])
    if result.returncode != 0:
        raise NagiosCmdError(result.stdout.rstrip())


def write_text_atomic(path: Path, content: str, force: bool = False, validate: bool = True) -> None:
    """Atomically write a file and roll back if Nagios validation fails."""
    if path.exists():
        confirm(f"Overwrite {path}?", force=force)
    path.parent.mkdir(parents=True, exist_ok=True)
    old_exists = path.exists()
    old_content = path.read_text(encoding="utf-8") if old_exists else None
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=str(path.parent), delete=False) as tmp:
        tmp_path = Path(tmp.name)
        tmp.write(content)
    os.chmod(tmp_path, 0o644)
    shutil.move(str(tmp_path), str(path))
    if not validate:
        return
    try:
        validate_config()
    except Exception:
        if old_exists and old_content is not None:
            path.write_text(old_content, encoding="utf-8")
            os.chmod(path, 0o644)
        else:
            path.unlink(missing_ok=True)
        raise


def object_block(object_type: str, fields: Dict[str, str]) -> str:
    """Render one Nagios object definition from ordered key/value fields."""
    lines = [f"define {object_type} {{"]
    for key, value in fields.items():
        lines.append(f"    {key:<28} {value}")
    lines.append("}")
    return "\n".join(lines) + "\n"


def parse_objects_from_text(text: str, path: Path) -> List[NagiosObject]:
    """Parse typical Nagios define-object blocks from text."""
    objects: List[NagiosObject] = []
    pattern = re.compile(r"define\s+([A-Za-z0-9_]+)\s*\{(.*?)\}", re.DOTALL)
    for match in pattern.finditer(text):
        fields: Dict[str, str] = {}
        for raw_line in match.group(2).splitlines():
            line = raw_line.strip()
            if not line or line.startswith("#"):
                continue
            if ";" in line:
                line = line.split(";", 1)[0].rstrip()
            parts = line.split(None, 1)
            if len(parts) == 2:
                fields[parts[0]] = parts[1].strip()
        objects.append(NagiosObject(match.group(1), fields, path, match.start(), match.end(), match.group(0)))
    return objects


def iter_cfg_files() -> Iterable[Path]:
    """Yield all .cfg files under the objects directory."""
    if not OBJECTS_DIR.exists():
        return []
    return sorted(OBJECTS_DIR.rglob("*.cfg"))


def iter_objects(resource: Optional[str] = None) -> Iterable[NagiosObject]:
    """Yield parsed objects, optionally filtered by nagios-cmd resource."""
    for path in iter_cfg_files():
        try:
            text = path.read_text(encoding="utf-8")
        except (UnicodeDecodeError, FileNotFoundError):
            continue
        for obj in parse_objects_from_text(text, path):
            if resource is None:
                yield obj
            elif resource == "template":
                if "name" in obj.fields and obj.fields.get("register") == "0":
                    yield obj
            elif obj.object_type == RESOURCE_META[resource]["object_type"]:
                yield obj


def object_name(resource: str, obj: NagiosObject) -> Optional[str]:
    """Return the logical display name for a parsed object."""
    if resource == "service":
        host_name = obj.fields.get("host_name", "")
        service_description = obj.fields.get("service_description", "")
        return f"{host_name}/{service_description}" if host_name and service_description else service_description or None
    return obj.fields.get(RESOURCE_META[resource]["name_key"])


def find_object(resource: str, name: str, second: Optional[str] = None) -> Optional[NagiosObject]:
    """Find an object by logical name; service uses host_name + service_description."""
    if resource == "service":
        for obj in iter_objects("service"):
            if obj.fields.get("host_name") == name and obj.fields.get("service_description") == second:
                return obj
        return None
    name_key = RESOURCE_META[resource]["name_key"]
    for obj in iter_objects(resource):
        if obj.fields.get(name_key) == name:
            return obj
    return None


def default_owned_files() -> set[Path]:
    """Return files known to be Ansible/default-owned and read-only to this tool."""
    files: set[Path] = set()
    for meta in RESOURCE_META.values():
        for path in meta["default_files"]:
            if path.exists():
                files.add(path.resolve())
    return files


def object_is_custom(obj: NagiosObject) -> bool:
    """Return True when an object is in a file nagios-cmd may modify."""
    path = obj.path.resolve()
    if path in default_owned_files():
        return False
    try:
        return path.is_relative_to(OBJECTS_DIR.resolve())
    except AttributeError:
        return str(path).startswith(str(OBJECTS_DIR.resolve()))


def custom_object_path(resource: str, name: str, hostgroup: Optional[str] = None) -> Path:
    """Calculate the target custom file path for a resource object."""
    safe_name(name, resource)
    if resource == "host":
        group = safe_name(hostgroup or DEFAULT_HOSTGROUP, "hostgroup")
        return HOSTS_DIR / group / f"{name}.cfg"
    if resource == "hostgroup":
        return HOSTS_DIR / safe_name(name, "hostgroup") / "hostgroup.cfg"
    return RESOURCE_META[resource]["custom_dir"] / f"{name}.cfg"


def ensure_hostgroup_file(hostgroup: str, force: bool = True) -> Path:
    """Ensure a hostgroup directory and hostgroup.cfg exist."""
    hostgroup = safe_name(hostgroup, "hostgroup")
    target = custom_object_path("hostgroup", hostgroup)
    if not target.exists():
        fields = {"hostgroup_name": hostgroup, "alias": hostgroup}
        write_text_atomic(target, object_block("hostgroup", fields), force=force)
    return target


def fields_for_add(resource: str, args: argparse.Namespace) -> Dict[str, str]:
    """Build initial Nagios fields for an add command and merge -o options."""
    options = parse_options(args.options)
    if resource == "host":
        fields = {"use": options.pop("use", "generic-host"), "host_name": args.name, "alias": options.pop("alias", args.name), "address": args.address, "hostgroups": args.hostgroup or DEFAULT_HOSTGROUP}
    elif resource == "hostgroup":
        fields = {"hostgroup_name": args.name, "alias": options.pop("alias", args.name)}
    elif resource == "servicegroup":
        fields = {"servicegroup_name": args.name, "alias": options.pop("alias", args.name)}
        if args.members:
            fields["members"] = args.members
        if args.servicegroup_members:
            fields["servicegroup_members"] = args.servicegroup_members
    elif resource == "contact":
        fields = {"contact_name": args.name, "alias": options.pop("alias", args.name)}
    elif resource == "contactgroup":
        fields = {"contactgroup_name": args.name, "alias": options.pop("alias", args.name)}
        if args.members:
            fields["members"] = args.members
        if args.contactgroup_members:
            fields["contactgroup_members"] = args.contactgroup_members
    elif resource == "command":
        fields = {"command_name": args.name}
    elif resource == "template":
        fields = {"name": args.name, "register": options.pop("register", "0")}
    elif resource == "timeperiod":
        fields = {"timeperiod_name": args.name, "alias": options.pop("alias", args.name)}
    else:
        die(f"unsupported resource: {resource}")
    fields.update(options)
    return fields


def update_object(obj: NagiosObject, fields: Dict[str, str], force: bool) -> None:
    """Update directives on an existing custom object."""
    if not object_is_custom(obj):
        die(f"refusing to modify Ansible/default-owned object in {obj.path}")
    text = read_text(obj.path)
    parsed_objects = parse_objects_from_text(text, obj.path)
    target = None
    for candidate in parsed_objects:
        if candidate.start == obj.start and candidate.end == obj.end:
            target = candidate
            break
    if target is None:
        die(f"could not locate object block in {obj.path}")
    updated_fields = dict(target.fields)
    updated_fields.update(fields)
    new_block = object_block(target.object_type, updated_fields).rstrip()
    new_text = text[:target.start] + new_block + text[target.end:]
    write_text_atomic(obj.path, new_text.strip() + "\n", force=force)


def remove_object(obj: NagiosObject, force: bool) -> None:
    """Remove a custom object and delete its file if it becomes empty."""
    if not object_is_custom(obj):
        die(f"refusing to remove Ansible/default-owned object in {obj.path}")
    confirm(f"Remove object from {obj.path}?", force=force)
    original_text = read_text(obj.path)
    new_text = (original_text[:obj.start] + original_text[obj.end:]).strip()
    if new_text:
        write_text_atomic(obj.path, new_text + "\n", force=True)
        return
    obj.path.unlink()
    try:
        validate_config()
    except Exception:
        obj.path.write_text(original_text, encoding="utf-8")
        os.chmod(obj.path, 0o644)
        raise


def render_template(text: str, variables: Dict[str, str]) -> str:
    """Replace {{ key }} placeholders using Nagios object field variables."""
    def replace(match: re.Match) -> str:
        key = match.group(1).strip()
        return variables.get(key, match.group(0))
    return re.sub(r"\{\{\s*([A-Za-z0-9_]+)\s*\}\}", replace, text)


def service_template_path(name: str) -> Path:
    """Return the path for a service definition template by name."""
    return SERVICEDEFS_DIR / f"{safe_name(name, 'service definition')}.tpl"


def cmd_generic_add(args: argparse.Namespace) -> int:
    """Add host, hostgroup, servicegroup, contact, contactgroup, command, template, or timeperiod."""
    ensure_layout()
    resource = args.resource
    name = safe_name(args.name, resource)
    existing = find_object(resource, name)
    if existing:
        confirm(f"{resource} {name} already exists in {existing.path}. Continue?", force=args.force)
    if resource == "host":
        ensure_hostgroup_file(args.hostgroup or DEFAULT_HOSTGROUP, force=True)
    object_type = args.object_type if resource == "template" else RESOURCE_META[resource]["object_type"]
    target = custom_object_path(resource, name, getattr(args, "hostgroup", None))
    fields = fields_for_add(resource, args)
    write_text_atomic(target, object_block(object_type, fields), force=args.force)
    print(f"Path: {target}")
    return 0


def cmd_generic_list(args: argparse.Namespace) -> int:
    """List object names and paths for a resource, including default-owned files."""
    rows = []
    for obj in iter_objects(args.resource):
        name = object_name(args.resource, obj)
        if name:
            rows.append((name, obj.path))
    if not rows:
        print(f"No {args.resource} objects found.")
        return 0
    for name, path in sorted(rows):
        print(f"{name}\t{path}")
    return 0


def cmd_generic_show(args: argparse.Namespace) -> int:
    """Show one object's raw config, or list objects if no name is given."""
    if not args.name:
        return cmd_generic_list(args)
    obj = find_object(args.resource, args.name)
    if obj is None:
        die(f"{args.resource} not found: {args.name}")
    print(f"Path: {obj.path}\n")
    print(obj.raw.rstrip())
    return 0


def cmd_generic_get(args: argparse.Namespace) -> int:
    """Print one directive or all parsed directives for an object."""
    obj = find_object(args.resource, args.name)
    if obj is None:
        die(f"{args.resource} not found: {args.name}")
    if args.key:
        print(obj.fields.get(args.key, ""))
    else:
        for key, value in obj.fields.items():
            print(f"{key}={value}")
    return 0


def cmd_generic_set(args: argparse.Namespace) -> int:
    """Set directives on an existing custom object."""
    obj = find_object(args.resource, args.name)
    if obj is None:
        die(f"{args.resource} not found: {args.name}")
    fields = parse_options(args.options)
    if args.resource == "host":
        if args.address:
            fields["address"] = args.address
        if args.hostgroup:
            fields["hostgroups"] = args.hostgroup
            ensure_hostgroup_file(args.hostgroup, force=True)
    if args.resource == "servicegroup":
        if args.members:
            fields["members"] = args.members
        if args.servicegroup_members:
            fields["servicegroup_members"] = args.servicegroup_members
    if args.resource == "contactgroup":
        if args.members:
            fields["members"] = args.members
        if args.contactgroup_members:
            fields["contactgroup_members"] = args.contactgroup_members
    if not fields:
        die("nothing to set; use -o key=value or a resource-specific option")
    update_object(obj, fields, force=args.force)
    print(f"updated {args.resource}: {args.name}")
    return 0


def cmd_generic_remove(args: argparse.Namespace) -> int:
    """Remove a custom object by name."""
    obj = find_object(args.resource, args.name)
    if obj is None:
        die(f"{args.resource} not found: {args.name}")
    remove_object(obj, force=args.force)
    print(f"removed {args.resource}: {args.name}")
    return 0


def cmd_service_list(args: argparse.Namespace) -> int:
    """List service templates, show a template, list host services, or show one host service."""
    ensure_layout()
    if args.name and not args.service_description:
        tpl = service_template_path(args.name)
        if tpl.exists():
            print(f"Path: {tpl}\n")
            print(read_text(tpl).rstrip())
            return 0
        rows = []
        for obj in iter_objects("service"):
            if obj.fields.get("host_name") == args.name:
                rows.append((obj.fields.get("service_description", ""), obj.path))
        if rows:
            for service_description, path in sorted(rows):
                print(f"{service_description}\t{path}")
            return 0
        die(f"no service template or host services found for: {args.name}")
    if args.name and args.service_description:
        obj = find_object("service", args.name, args.service_description)
        if obj is None:
            die(f"service not found: {args.name}/{args.service_description}")
        print(f"Path: {obj.path}\n")
        print(obj.raw.rstrip())
        return 0
    templates = sorted(SERVICEDEFS_DIR.glob("*.tpl"))
    if not templates:
        print("No service definition templates found.")
        return 0
    for path in templates:
        print(f"{path.stem}\t{path}")
    return 0


def cmd_service_add(args: argparse.Namespace) -> int:
    """Render service definition templates and append them to a host config file."""
    ensure_layout()
    hostname = safe_name(args.hostname, "hostname")
    host_obj = find_object("host", hostname)
    if host_obj is None:
        die(f"host not found: {hostname}")
    hostgroup = host_obj.fields.get("hostgroups", DEFAULT_HOSTGROUP).split(",", 1)[0] or DEFAULT_HOSTGROUP
    target = custom_object_path("host", hostname, hostgroup)
    if not target.exists():
        die(f"host config file not found: {target}")
    services = [safe_name(s.strip(), "service definition") for s in args.services.split(",") if s.strip()]
    if not services:
        die("no services specified")
    variables = dict(host_obj.fields)
    variables.setdefault("host_name", hostname)
    additions = []
    for service_name in services:
        tpl = service_template_path(service_name)
        if not tpl.exists():
            die(f"service definition template not found: {tpl}")
        template_vars = dict(variables)
        template_vars.setdefault("service_description", service_name)
        rendered = render_template(read_text(tpl), template_vars).rstrip()
        for obj in parse_objects_from_text(rendered, tpl):
            if obj.object_type == "service":
                desc = obj.fields.get("service_description", service_name)
                existing = find_object("service", hostname, desc)
                if existing is not None:
                    confirm(f"service {hostname}/{desc} already exists in {existing.path}. Continue?", force=args.force)
        additions.append(f"\n# BEGIN nagios-cmd service {service_name}\n{rendered}\n# END nagios-cmd service {service_name}\n")
    new_content = read_text(target).rstrip() + "\n" + "".join(additions)
    write_text_atomic(target, new_content, force=args.force)
    print(f"added services to {hostname}: {', '.join(services)}")
    return 0


def cmd_service_remove(args: argparse.Namespace) -> int:
    """Remove one or more service objects from a host by service_description."""
    hostname = safe_name(args.hostname, "hostname")
    service_descriptions = [s.strip() for s in args.service_description.split(",") if s.strip()]
    if not service_descriptions:
        die("no service descriptions specified")
    for service_description in service_descriptions:
        obj = find_object("service", hostname, service_description)
        if obj is None:
            die(f"service not found: {hostname}/{service_description}")
        remove_object(obj, force=args.force)
    print(f"removed services from {hostname}: {', '.join(service_descriptions)}")
    return 0


def cmd_service_get(args: argparse.Namespace) -> int:
    """Print one directive or all directives for a configured service object."""
    obj = find_object("service", args.hostname, args.service_description)
    if obj is None:
        die(f"service not found: {args.hostname}/{args.service_description}")
    if args.key:
        print(obj.fields.get(args.key, ""))
    else:
        for key, value in obj.fields.items():
            print(f"{key}={value}")
    return 0


def cmd_service_set(args: argparse.Namespace) -> int:
    """Set directives on an existing custom service object."""
    obj = find_object("service", args.hostname, args.service_description)
    if obj is None:
        die(f"service not found: {args.hostname}/{args.service_description}")
    fields = parse_options(args.options)
    if not fields:
        die("nothing to set; use -o key=value")
    update_object(obj, fields, force=args.force)
    print(f"updated service: {args.hostname}/{args.service_description}")
    return 0


def cmd_config_check(args: argparse.Namespace) -> int:
    """Validate the active Nagios configuration."""
    try:
        validate_config()
    except NagiosCmdError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    print("Nagios configuration OK")
    return 0


def cmd_config_list(args: argparse.Namespace) -> int:
    """List discovered configuration file paths under objects/."""
    for path in iter_cfg_files():
        print(path)
    return 0


def cmd_config_dump(args: argparse.Namespace) -> int:
    """Dump concatenated configuration to stdout with path markers."""
    first = True
    for path in iter_cfg_files():
        if not first:
            print()
        first = False
        print(f"# BEGIN {path}")
        print(read_text(path).rstrip())
        print(f"# END {path}")
    return 0


def cmd_config_backup(args: argparse.Namespace) -> int:
    """Create a tar.gz backup of nagios.cfg, objects/, and servicedefs/."""
    destination_dir = Path(args.directory).expanduser() if args.directory else BACKUP_DIR
    destination_dir.mkdir(parents=True, exist_ok=True)
    timestamp = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
    backup_path = destination_dir / f"nagios-config-backup-{timestamp}.tar.gz"
    with tarfile.open(backup_path, "w:gz") as archive:
        for path in [NAGIOS_CFG, OBJECTS_DIR, SERVICEDEFS_DIR]:
            if path.exists():
                archive.add(path, arcname=str(path.relative_to("/")))
    print(backup_path)
    return 0


def cmd_config_reload(args: argparse.Namespace) -> int:
    """Validate configuration and reload the Nagios systemd service."""
    check_result = cmd_config_check(args)
    if check_result != 0:
        return check_result
    result = run_command(["systemctl", "reload", NAGIOS_SERVICE])
    if result.returncode != 0:
        die(result.stdout.rstrip() or f"failed to reload {NAGIOS_SERVICE}")
    print(f"reloaded {NAGIOS_SERVICE}")
    return 0


def add_generic_resource_parser(subparsers: argparse._SubParsersAction, resource: str) -> None:
    """Register add/remove/show/list/set/get argparse actions for a generic resource."""
    parser = subparsers.add_parser(resource, help=f"Manage {resource} objects")
    actions = parser.add_subparsers(dest="action", required=True)
    add_parser = actions.add_parser("add", help=f"Add {resource}")
    add_parser.add_argument("name")
    if resource == "host":
        add_parser.add_argument("address")
        add_parser.add_argument("-g", "--hostgroup", default=DEFAULT_HOSTGROUP)
    if resource == "template":
        add_parser.add_argument("--object-type", choices=["host", "service", "contact"], default="host", help="Nagios object type for this template")
    if resource == "servicegroup":
        add_parser.add_argument("-m", "--members", help="Servicegroup members as host,service,host,service")
        add_parser.add_argument("--servicegroup-members", help="Comma-separated nested servicegroup members")
    if resource == "contactgroup":
        add_parser.add_argument("-m", "--members", help="Comma-separated contact members")
        add_parser.add_argument("--contactgroup-members", help="Comma-separated nested contactgroup members")
    add_parser.add_argument("-o", "--options", action="append", help="Nagios directive(s): key=value or key=value,key=value")
    add_parser.add_argument("-f", "--force", action="store_true", help="Do not prompt before overwrite")
    add_parser.set_defaults(func=cmd_generic_add, resource=resource)
    for alias in ("show", "list"):
        show_parser = actions.add_parser(alias, help=f"{alias.capitalize()} {resource} objects")
        show_parser.add_argument("name", nargs="?")
        show_parser.set_defaults(func=cmd_generic_show if alias == "show" else cmd_generic_list, resource=resource)
    get_parser = actions.add_parser("get", help=f"Get {resource} directive values")
    get_parser.add_argument("name")
    get_parser.add_argument("key", nargs="?")
    get_parser.set_defaults(func=cmd_generic_get, resource=resource)
    set_parser = actions.add_parser("set", help=f"Set {resource} directive values")
    set_parser.add_argument("name")
    if resource == "host":
        set_parser.add_argument("address", nargs="?")
        set_parser.add_argument("-g", "--hostgroup")
    if resource == "servicegroup":
        set_parser.add_argument("-m", "--members", help="Servicegroup members as host,service,host,service")
        set_parser.add_argument("--servicegroup-members", help="Comma-separated nested servicegroup members")
    if resource == "contactgroup":
        set_parser.add_argument("-m", "--members", help="Comma-separated contact members")
        set_parser.add_argument("--contactgroup-members", help="Comma-separated nested contactgroup members")
    set_parser.add_argument("-o", "--options", action="append", help="Nagios directive(s): key=value or key=value,key=value")
    set_parser.add_argument("-f", "--force", action="store_true", help="Do not prompt before overwrite")
    set_parser.set_defaults(func=cmd_generic_set, resource=resource)
    remove_parser = actions.add_parser("remove", help=f"Remove {resource}")
    remove_parser.add_argument("name")
    remove_parser.add_argument("-f", "--force", action="store_true", help="Do not prompt before removal")
    remove_parser.set_defaults(func=cmd_generic_remove, resource=resource)


def add_service_parser(subparsers: argparse._SubParsersAction) -> None:
    """Register service-specific argparse actions."""
    parser = subparsers.add_parser("service", help="Manage services and service definition templates")
    actions = parser.add_subparsers(dest="action", required=True)
    for alias in ("show", "list"):
        show_parser = actions.add_parser(alias, help="Show/list service templates or configured services")
        show_parser.add_argument("name", nargs="?")
        show_parser.add_argument("service_description", nargs="?")
        show_parser.set_defaults(func=cmd_service_list)
    add_parser = actions.add_parser("add", help="Add service template(s) to a host")
    add_parser.add_argument("hostname")
    add_parser.add_argument("-s", "--services", required=True, help="Comma-separated service definition template names")
    add_parser.add_argument("-f", "--force", action="store_true", help="Do not prompt before overwrite")
    add_parser.set_defaults(func=cmd_service_add)
    remove_parser = actions.add_parser("remove", help="Remove service object(s) from a host")
    remove_parser.add_argument("hostname")
    remove_parser.add_argument("service_description", help="Service description or comma-separated descriptions")
    remove_parser.add_argument("-f", "--force", action="store_true", help="Do not prompt before removal")
    remove_parser.set_defaults(func=cmd_service_remove)
    get_parser = actions.add_parser("get", help="Get service directive values")
    get_parser.add_argument("hostname")
    get_parser.add_argument("service_description")
    get_parser.add_argument("key", nargs="?")
    get_parser.set_defaults(func=cmd_service_get)
    set_parser = actions.add_parser("set", help="Set service directive values")
    set_parser.add_argument("hostname")
    set_parser.add_argument("service_description")
    set_parser.add_argument("-o", "--options", action="append", required=True, help="Nagios directive(s): key=value or key=value,key=value")
    set_parser.add_argument("-f", "--force", action="store_true", help="Do not prompt before overwrite")
    set_parser.set_defaults(func=cmd_service_set)


def add_config_parser(subparsers: argparse._SubParsersAction) -> None:
    """Register config utility argparse actions."""
    parser = subparsers.add_parser("config", help="Configuration utilities")
    actions = parser.add_subparsers(dest="action", required=True)
    check_parser = actions.add_parser("check", help="Run Nagios validation")
    check_parser.set_defaults(func=cmd_config_check)
    list_parser = actions.add_parser("list", help="List configuration file paths")
    list_parser.set_defaults(func=cmd_config_list)
    dump_parser = actions.add_parser("dump", help="Dump concatenated configuration")
    dump_parser.set_defaults(func=cmd_config_dump)
    backup_parser = actions.add_parser("backup", help="Create tar.gz backup")
    backup_parser.add_argument("directory", nargs="?", help=f"Backup destination directory; default: {BACKUP_DIR}")
    backup_parser.set_defaults(func=cmd_config_backup)
    reload_parser = actions.add_parser("reload", help="Validate and reload Nagios")
    reload_parser.set_defaults(func=cmd_config_reload)


def build_parser() -> argparse.ArgumentParser:
    """Build the top-level CLI parser and subcommands."""
    parser = argparse.ArgumentParser(prog="nagios-cmd", description="Manage custom Nagios configuration")
    subparsers = parser.add_subparsers(dest="resource", required=True)
    help_parser = subparsers.add_parser("help", help="Show help")
    help_parser.set_defaults(func=lambda args: (parser.print_help() or 0))
    for resource in ["host", "hostgroup", "servicegroup", "contact", "contactgroup", "command", "template", "timeperiod"]:
        add_generic_resource_parser(subparsers, resource)
    add_service_parser(subparsers)
    add_config_parser(subparsers)
    return parser


def main() -> int:
    """Program entry point; dispatch argparse commands and handle errors cleanly."""
    parser = build_parser()
    args = parser.parse_args()
    try:
        return args.func(args)
    except NagiosCmdError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    except PermissionError as exc:
        print(f"permission denied: {exc}", file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print("interrupted", file=sys.stderr)
        return 130


if __name__ == "__main__":
    raise SystemExit(main())